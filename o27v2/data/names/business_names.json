  "naming_pattern": {
    "_comment": "Generation algorithm.",
    "steps": [
      "1. Select a city from the team's locale per the league's name_regions.",
      "2. Decide locale_sub within the region (e.g., for Subcontinent: hindi vs urdu vs arabic vs english based on the city's primary language).",
      "3. With ~40% probability, prepend a modifier from modifiers_optional.",
      "4. Select a business type: 70% from business_types_global, 30% from the region's flavor extras — preferring a locale-specific <lang>_business_types_extra list (so a Portuguese city never draws a Spanish type) and falling back to the region-wide preferred_business_types_extra for regions not yet split by locale.",
      "5. With ~50% probability, append a locale-appropriate suffix from the region's suffix_options.",
      "6. Capitalize and combine: '<City> <Modifier?> <Business Type><Suffix?>'."
    ],
    "examples_of_generated_output": [
      "Lagos United Foundry & Co.",
      "Mumbai Royal Spice Market & Sons",
      "Sapporo Eastern Tea Importers Honten",
      "Hamburg Crown Bäckerei GmbH",
      "Manila Pacific Sari-sari Store",
      "Buenos Aires Hermanos Provisioners",
      "Kuala Lumpur Northern Tin Co. Sdn Bhd",
      "Stockholm Modern Glasbruk AB"
    ]
  },

