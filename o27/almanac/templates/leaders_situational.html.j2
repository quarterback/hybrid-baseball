{% extends "_base.html.j2" %}
{% block title %}Situational — {{ site_title }}{% endblock %}
{% block content %}
<h1 class="page-title">Situational Stats</h1>
<p class="page-subtitle">Per-base runner-advancement, 2C conversion, monthly splits.</p>

<div class="section-bar">
  <div class="tabs">
    <a href="batting.html">Batting</a>
    <a href="pitching.html">Pitching</a>
    <a href="fielding.html">Fielding</a>
    <a href="value.html">Value (WAR)</a>
    <a href="stays.html">Stays</a>
    <a class="active" href="situational.html">Situational</a>
  </div>
</div>

<section>
  <div class="section-bar">
    <h2>Per-Base Runner Advancement (Any-Cause)</h2>
    <div class="btn-row">
      <button class="btn" data-export-csv="#adv-tbl" data-filename="advancement-leaders.csv">CSV</button>
    </div>
  </div>
  <div class="tablewrap">
    <table id="adv-tbl" class="stat-table heatmap">
      <thead><tr>
        <th class="sticky-col" data-type="text">Player</th>
        <th data-type="text">Team</th>
        <th>PA</th>
        <th data-heat="hi">OP·1B</th><th data-heat="hi">ADV·1B</th><th data-heat="hi">CONV·1B</th>
        <th data-heat="hi">OP·2B</th><th data-heat="hi">ADV·2B</th><th data-heat="hi">CONV·2B</th>
        <th data-heat="hi">OP·3B</th><th data-heat="hi">ADV·3B</th><th data-heat="hi">CONV·3B</th>
        <th data-heat="hi">OP·TOT</th><th data-heat="hi">ADV·TOT</th>
        <th data-heat="hi">CONV·TOT</th>
      </tr></thead>
      <tbody>
        {% for r in views.batting_season if r.qualified %}
        <tr>
          <td class="sticky-col t-left"><a href="../players/{{ r.team|lower }}_{{ r.slug }}.html">{{ r.name }}</a></td>
          <td class="t-left"><a href="../teams/{{ r.team|lower }}.html"><span class="chip">{{ r.team }}</span></a></td>
          <td>{{ r.pa }}</td>
          <td>{{ r.adv_op_1b }}</td>
          <td>{{ r.adv_adv_1b }}</td>
          <td data-val="{{ r.adv_conv_1b }}">{{ '%.0f'|format(r.adv_conv_1b * 100) }}%</td>
          <td>{{ r.adv_op_2b }}</td>
          <td>{{ r.adv_adv_2b }}</td>
          <td data-val="{{ r.adv_conv_2b }}">{{ '%.0f'|format(r.adv_conv_2b * 100) }}%</td>
          <td>{{ r.adv_op_3b }}</td>
          <td>{{ r.adv_adv_3b }}</td>
          <td data-val="{{ r.adv_conv_3b }}">{{ '%.0f'|format(r.adv_conv_3b * 100) }}%</td>
          <td>{{ r.adv_op_total }}</td>
          <td>{{ r.adv_adv_total }}</td>
          <td data-val="{{ r.adv_conv_total }}">{{ '%.0f'|format(r.adv_conv_total * 100) }}%</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section>
  <div class="section-bar">
    <h2>2C (Stay) Per-Base Conversion</h2>
    <div class="btn-row">
      <button class="btn" data-export-csv="#c2-tbl" data-filename="2c-conversion-leaders.csv">CSV</button>
    </div>
  </div>
  <div class="tablewrap">
    <table id="c2-tbl" class="stat-table heatmap">
      <thead><tr>
        <th class="sticky-col" data-type="text">Player</th>
        <th data-type="text">Team</th>
        <th>STY</th>
        <th data-heat="hi">C2_OP·1B</th><th data-heat="hi">C2_ADV·1B</th><th data-heat="hi">C2_CONV·1B</th>
        <th data-heat="hi">C2_OP·2B</th><th data-heat="hi">C2_ADV·2B</th><th data-heat="hi">C2_CONV·2B</th>
        <th data-heat="hi">C2_OP·3B</th><th data-heat="hi">C2_ADV·3B</th><th data-heat="hi">C2_CONV·3B</th>
        <th data-heat="hi">TOTAL OP</th><th data-heat="hi">TOTAL ADV</th>
        <th data-heat="hi">CONV%</th>
      </tr></thead>
      <tbody>
        {% for r in views.batting_season if r.qualified %}
        <tr>
          <td class="sticky-col t-left"><a href="../players/{{ r.team|lower }}_{{ r.slug }}.html">{{ r.name }}</a></td>
          <td class="t-left"><a href="../teams/{{ r.team|lower }}.html"><span class="chip">{{ r.team }}</span></a></td>
          <td>{{ r.stays }}</td>
          <td>{{ r.c2_op_1b }}</td>
          <td>{{ r.c2_adv_1b }}</td>
          <td data-val="{{ r.c2_conv_1b }}">{{ '%.0f'|format(r.c2_conv_1b * 100) }}%</td>
          <td>{{ r.c2_op_2b }}</td>
          <td>{{ r.c2_adv_2b }}</td>
          <td data-val="{{ r.c2_conv_2b }}">{{ '%.0f'|format(r.c2_conv_2b * 100) }}%</td>
          <td>{{ r.c2_op_3b }}</td>
          <td>{{ r.c2_adv_3b }}</td>
          <td data-val="{{ r.c2_conv_3b }}">{{ '%.0f'|format(r.c2_conv_3b * 100) }}%</td>
          <td>{{ r.c2_op_total }}</td>
          <td>{{ r.c2_adv_total }}</td>
          <td data-val="{{ r.c2_conv_total }}">{{ '%.0f'|format(r.c2_conv_total * 100) }}%</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section>
  <div class="section-bar">
    <h2>Monthly League Splits</h2>
    <div class="btn-row"><button class="btn" data-export-csv="#monthly-tbl" data-filename="monthly-splits.csv">CSV</button></div>
  </div>
  <div class="tablewrap short">
    <table id="monthly-tbl" class="stat-table heatmap">
      <thead><tr>
        <th class="sticky-col" data-type="text">Month</th>
        <th>G</th><th>PA</th>
        <th data-heat="hi">R</th><th data-heat="hi">H</th><th data-heat="hi">HR</th>
        <th data-heat="hi">BB</th><th data-heat="lo">K</th><th data-heat="hi">STY</th>
        <th data-heat="hi">AVG</th><th data-heat="hi">OBP</th>
        <th data-heat="hi">SLG</th><th data-heat="hi">OPS</th>
        <th data-heat="lo">ERA</th><th data-heat="lo">WHIP</th>
      </tr></thead>
      <tbody>
        {% for m in views.monthly_splits %}
        <tr>
          <td class="sticky-col t-left">{{ m.month }}</td>
          <td>{{ m.g }}</td>
          <td>{{ m.pa }}</td>
          <td>{{ m.runs }}</td>
          <td>{{ m.h }}</td>
          <td>{{ m.hr }}</td>
          <td>{{ m.bb }}</td>
          <td>{{ m.k }}</td>
          <td>{{ m.stays }}</td>
          <td data-val="{{ m.avg }}">{{ '%.3f'|format(m.avg) }}</td>
          <td data-val="{{ m.obp }}">{{ '%.3f'|format(m.obp) }}</td>
          <td data-val="{{ m.slg }}">{{ '%.3f'|format(m.slg) }}</td>
          <td data-val="{{ m.ops }}">{{ '%.3f'|format(m.ops) }}</td>
          <td data-val="{{ m.era }}">{{ '%.2f'|format(m.era) }}</td>
          <td data-val="{{ m.whip }}">{{ '%.2f'|format(m.whip) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
