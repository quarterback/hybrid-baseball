<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ site_title }}{% endblock %}</title>
  <link rel="stylesheet" href="{{ '../' * depth }}static/almanac.css">
  <script defer src="{{ '../' * depth }}static/almanac.js"></script>
</head>
<body>
<header class="site">
  <div class="site-bar">
    <div class="brand">{{ site_title }}<span class="sub">{{ subtitle }}</span></div>
    <nav class="top">
      <a href="{{ '../' * depth }}index.html"           {% if section == 'home'      %}class="active"{% endif %}>Home</a>
      <a href="{{ '../' * depth }}standings.html"       {% if section == 'standings' %}class="active"{% endif %}>Standings</a>
      <a href="{{ '../' * depth }}schedule.html"        {% if section == 'schedule'  %}class="active"{% endif %}>Schedule</a>
      <a href="{{ '../' * depth }}leaders/batting.html" {% if section == 'leaders'   %}class="active"{% endif %}>Leaders</a>
      <a href="{{ '../' * depth }}teams/index.html"     {% if section == 'teams'     %}class="active"{% endif %}>Teams</a>
      <a href="{{ '../' * depth }}players/index.html"   {% if section == 'players'   %}class="active"{% endif %}>Players</a>
      <a href="{{ '../' * depth }}exports/index.html"   {% if section == 'exports'   %}class="active"{% endif %}>Export</a>
    </nav>
    <span class="spacer"></span>
    <input class="search-box" placeholder="Find player…" data-filter-table="#player-index" data-filter-cols="0,1">
    <button class="theme-toggle" type="button">Dark</button>
  </div>
</header>
<main>
  {% block content %}{% endblock %}
</main>
<footer class="site">
  Generated by <code>o27.almanac</code> · source: {{ source_label }} · {{ generated_at }}
</footer>
</body>
</html>
