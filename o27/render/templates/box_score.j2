{#- box_score.j2 — Full O27 box score in §4.7 reference format
    Uses Python %-format via the |format filter; ljust registered as custom filter.
-#}
{%- macro row(s) -%}
{{ "%-20s" | format(s.name) }}  {{ "%3d" | format(s.pa) }}  {{ "%3d" | format(s.ab) }}  {{ "%3d" | format(s.runs) }}  {{ "%3d" | format(s.hits) }}  {{ "%3d" | format(s.doubles) }}  {{ "%3d" | format(s.triples) }}  {{ "%3d" | format(s.hr) }}  {{ "%4d" | format(s.rbi) }}  {{ "%3d" | format(s.bb) }}  {{ "%3d" | format(s.k) }}  {{ "%3d" | format(s.sty) }}
{%- endmacro -%}
