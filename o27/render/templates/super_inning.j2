{#- super_inning.j2 — Super-inning round header, summary, or final log.
    The tie banner ("TIE — SUPER-INNING TIEBREAKER") is emitted separately
    by Renderer.render_super_inning_tie() and is NOT repeated here.
-#}
{% if mode == "header" %}

--- Super-Inning Round {{ round_num }} ---
{% elif mode == "summary" %}
  Super-inning R{{ round_num }}: {{ visitors_name }} {{ visitors_runs }} – {{ home_name }} {{ home_runs }}
{% elif mode == "final_log" %}

============================================================
SUPER-INNING LOG
============================================================
Winner: {{ winner_name }} (super-inning)
{% for pair in round_pairs %}
  Round {{ pair.round_num }}: {{ pair.v_name }} {{ pair.v_runs }} – {{ pair.h_name }} {{ pair.h_runs }}
{% endfor %}
{% endif %}
